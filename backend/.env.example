# Backend environment variables — set these in Render's "Environment" section
# for the backend Web Service.

# PostgreSQL connection string provided by Render after creating a PostgreSQL instance.
# (Render sets this automatically if you link the database to the service.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# A long random secret used to sign JWT tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-long-random-secret
